<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="auth-container">
    <h2 class="auth-title">Register Account</h2>
    
    <% if (error) { %>
      <div class="alert">
        <%= error %>
      </div>
    <% } %>

    <form action="/register" method="POST">
      <div class="form-group">
        <label for="name">Display Name</label>
        <input type="text" id="name" name="name" class="form-control" placeholder="e.g. John Doe" required>
      </div>

      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" class="form-control" placeholder="e.g. john_doe" required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="Create secure password" required>
      </div>

      <button type="submit" class="btn-auth">Register</button>
    </form>

    <div class="auth-switch">
      Already registered? <a href="/login">Log in here</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
